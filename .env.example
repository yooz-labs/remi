# App Store Connect upload credentials for scripts/testflight-ios.sh.
# Copy to .env (gitignored) and fill in. The key is team-level (same one yooz
# uses for whisper/notes), so it works for every yooz app.
#
# Get these from App Store Connect -> Users and Access -> Integrations -> Keys:
#   ASC_KEY_ID    = the key's Key ID (matches the AuthKey_<KEYID>.p8 filename)
#   ASC_ISSUER_ID = the team Issuer ID shown at the top of the keys page
# Place the .p8 at ~/.appstoreconnect/private_keys/AuthKey_<KEYID>.p8
ASC_KEY_ID=
ASC_ISSUER_ID=
