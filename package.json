{
  "name": "remi",
  "version": "0.6.21-dev.1",
  "private": true,
  "license": "UNLICENSED",
  "workspaces": ["packages/*"],
  "scripts": {
    "test": "bun test --coverage",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage --coverage-reporter=text --coverage-reporter=lcov",
    "test:e2e": "bunx playwright test --config tests/e2e/playwright.config.ts",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "daemon": "bun run packages/daemon/src/cli.ts",
    "daemon:dev": "bun --watch run packages/daemon/src/cli.ts",
    "remi": "bun run packages/daemon/src/cli.ts",
    "build:binary": "bun build --compile --outfile=dist/remi packages/daemon/src/cli.ts",
    "build:darwin-arm64": "bun build --compile --target=bun-darwin-arm64 --outfile=dist/remi-darwin-arm64 packages/daemon/src/cli.ts",
    "build:darwin-x64": "bun build --compile --target=bun-darwin-x64 --outfile=dist/remi-darwin-x64 packages/daemon/src/cli.ts",
    "build:linux-x64": "bun build --compile --target=bun-linux-x64 --outfile=dist/remi-linux-x64 packages/daemon/src/cli.ts",
    "build:linux-arm64": "bun build --compile --target=bun-linux-arm64 --outfile=dist/remi-linux-arm64 packages/daemon/src/cli.ts",
    "build:all": "bun run build:darwin-arm64 && bun run build:darwin-x64 && bun run build:linux-x64 && bun run build:linux-arm64",
    "install:local": "mkdir -p ~/.local/bin && cp dist/remi ~/.local/bin/remi",
    "app:version": "bun scripts/sync-app-version.mjs",
    "build:macos-web": "bash scripts/stage-macos-web.sh",
    "testflight:ios": "bash scripts/testflight-ios.sh",
    "testflight:macos": "bash scripts/testflight-macos.sh",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@playwright/test": "^1.58.2",
    "@types/bun": "^1.1.0",
    "lefthook": "^2.1.3",
    "typescript": "^5.7.0"
  },
  "dependencies": {
    "@capacitor/push-notifications": "^8.0.3"
  }
}
